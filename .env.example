# App URL (required for Slack "Open in Dashboard" links - set to your Vercel URL in production)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Storage (optional - defaults to form-documents)
STORAGE_BUCKET=form-documents

# SAM.gov (optional - for fetching opportunity details when pasting URL)
SAM_GOV_API_KEY=your-sam-gov-api-key

# Slack (for @ mentions, add users:read.email scope to your app at api.slack.com)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
# Legacy: single shared channel for “Create + thread in shared channel”
SLACK_CONTRACT_CHANNEL_ID=C0XXXXXXX

# Optional: set to true to create private channels (requires groups:write scope)
# SLACK_PROJECT_CHANNEL_PRIVATE=false
